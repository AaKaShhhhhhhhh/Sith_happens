# Supabase database
# Frontend uses anon key for realtime/read subscriptions.
# Vercel API routes use the service role key for trusted backend writes.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Access auth in front of the Vercel app/API
# Required if /api/* routes are protected by Cloudflare Access.
CLOUDFLARE_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=

# Optional Cloudflare API automation fields
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ElevenLabs — only needed to (re)generate suspect voice lines via `pnpm gen:audio`.
# Not read by the browser app; the generated .mp3s live in public/audio.
ELEVENLABS_API_KEY=
# Optional voice-id overrides:
# VOICE_CTO=
# VOICE_INTERN=
# VOICE_SENIOR_DEV=

# Optional analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
